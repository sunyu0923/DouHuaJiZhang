# 服务端口
PORT=8080

# PostgreSQL
POSTGRES_USER=douhua
POSTGRES_PASSWORD=douhua_secret_2026
POSTGRES_DB=douhuajizhang
DATABASE_URL=postgres://douhua:douhua_secret_2026@postgres:5432/douhuajizhang?sslmode=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# JWT (生产环境必须修改!)
